  <main class="pt-32 pb-20 px-4 md:px-8">
    <div class="max-w-[800px] mx-auto prose prose-invert prose-headings:font-display prose-headings:text-txt-primary prose-p:text-txt-secondary prose-li:text-txt-secondary prose-a:text-brand-light prose-strong:text-txt-primary">

