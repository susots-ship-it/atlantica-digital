---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Nav from '../../../../components/Nav.astro';
import Footer from '../../../../components/Footer.astro';
import BlogCard from '../../../../components/BlogCard.astro';
import { useTranslations } from '../../../../i18n/utils';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(post => post.data.lang === 'en');
  const locationMap = new Map<string, string>();
  posts.forEach(post => {
    post.data.location.forEach((loc, i) => {
      if (!locationMap.has(loc)) {
        locationMap.set(loc, post.data.locationLabels[i]);
      }
    });
  });

  return Array.from(locationMap.entries()).map(([slug, label]) => ({
    params: { location: slug },
    props: {
      locationSlug: slug,
      locationLabel: label,
      posts: posts.filter(p => p.data.location.includes(slug))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const lang = 'en' as const;
const t = useTranslations(lang);
const { locationLabel, posts } = Astro.props;
---

<BaseLayout lang={lang}>
  <Nav lang={lang} />

  <main class="pt-32 pb-20 px-4 md:px-8">
    <div class="max-w-[1200px] mx-auto">
      <div class="mb-8">
        <a href={`/${lang}/blog/`} class="text-brand-light hover:text-brand transition-colors text-sm font-medium">
          {t('blog.backToBlog')}
        </a>
      </div>

      <div class="text-center max-w-[600px] mx-auto mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-brand-glow border border-[rgba(59,130,246,0.15)] rounded-full mb-6">
          <svg class="w-4 h-4 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span class="text-sm font-medium text-brand-light">{locationLabel}</span>
        </div>
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-4">{t('blog.postsIn')} {locationLabel}</h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            slug={post.id}
            lang={lang}
            location={post.data.location}
            locationLabels={post.data.locationLabels}
            image={post.data.image}
          />
        ))}
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
