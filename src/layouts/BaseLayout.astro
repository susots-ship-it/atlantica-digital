---
import '../styles/global.css';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  image?: string;
}

const { lang, title: customTitle, description: customDescription, image: customImage } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'es' ? 'en' : 'es';

const siteUrl = 'https://www.travesia21.es';
const currentPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${currentPath}`;
const alternateLangUrl = `${siteUrl}${currentPath.replace(`/${lang}/`, `/${otherLang}/`)}`;
const defaultUrl = `${siteUrl}/`;

const pageTitle = customTitle || t('meta.title');
const pageDescription = customDescription || t('meta.description');
const pageImage = customImage || `${siteUrl}/og-image.svg`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Travesía21",
  "description": "Servicios digitales integrales para pymes y autónomos. Diseño web, hosting, SEO y marketing digital desde A Coruña.",
  "url": siteUrl,
  "email": "hola@travesia21.es",
  "logo": `${siteUrl}/favicon.svg`,
  "image": pageImage,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "A Coruña",
    "addressRegion": "Galicia",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.3623,
    "longitude": -8.4115
  },
  "areaServed": {
    "@type": "Country",
    "name": "España"
  },
  "priceRange": "€€",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "18:00"
  },
  "sameAs": [
    "https://www.instagram.com/travesia21",
    "https://www.linkedin.com/company/travesia21"
  ]
};
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary -->
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Hreflang -->
  <link rel="alternate" hreflang="es" href={lang === 'es' ? canonicalUrl : alternateLangUrl} />
  <link rel="alternate" hreflang="en" href={lang === 'en' ? canonicalUrl : alternateLangUrl} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/es/`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={pageImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Travesía21" />
  <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_GB'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={pageImage} />

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="font-body bg-surface-primary text-txt-primary leading-relaxed overflow-x-hidden antialiased">
  <slot />

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    window.addEventListener('scroll', () => {
      const nav = document.querySelector('nav');
      if (nav) {
        if (window.scrollY > 50) {
          nav.style.borderBottomColor = 'rgba(255,255,255,0.08)';
        } else {
          nav.style.borderBottomColor = 'rgba(255,255,255,0.03)';
        }
      }
    });
  </script>
</body>
</html>
