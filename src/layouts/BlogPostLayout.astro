---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    lang: Lang;
    location: string[];
    locationLabels: string[];
    image?: string;
    author: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
const lang = frontmatter.lang;
const t = useTranslations(lang);
const locationPath = lang === 'es' ? 'ubicacion' : 'location';
const formattedDate = new Date(frontmatter.date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout lang={lang}>
  <Nav lang={lang} />

  <main class="pt-32 pb-20 px-4 md:px-8">
    <article class="max-w-[800px] mx-auto">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-txt-muted">
        <a href={`/${lang}/`} class="hover:text-txt-primary transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href={`/${lang}/blog/`} class="hover:text-txt-primary transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-txt-secondary">{frontmatter.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-12">
        <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-6">{frontmatter.title}</h1>

        <div class="flex flex-wrap items-center gap-4 text-sm text-txt-secondary mb-6">
          <time datetime={frontmatter.date}>
            {t('blog.published')} {formattedDate}
          </time>
          <span class="text-txt-muted">·</span>
          <span>{t('blog.by')} {frontmatter.author}</span>
        </div>

        <!-- Location badges -->
        <div class="flex flex-wrap gap-2">
          {frontmatter.location.map((loc, i) => (
            <a
              href={`/${lang}/blog/${locationPath}/${loc}/`}
              class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium bg-brand-glow text-brand-light border border-[rgba(59,130,246,0.15)] rounded-full hover:bg-[rgba(59,130,246,0.25)] transition-colors"
            >
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              {frontmatter.locationLabels[i]}
            </a>
          ))}
        </div>
      </header>

      {frontmatter.image && (
        <img src={frontmatter.image} alt={frontmatter.title} class="w-full rounded-card mb-12 border border-border" />
      )}

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display prose-headings:text-txt-primary
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-txt-secondary prose-p:leading-relaxed
        prose-a:text-brand-light prose-a:no-underline hover:prose-a:underline
        prose-strong:text-txt-primary
        prose-li:text-txt-secondary
        prose-ul:my-4 prose-ol:my-4
        prose-blockquote:border-brand prose-blockquote:text-txt-secondary
      ">
        <slot />
      </div>

      <!-- Back to blog -->
      <div class="mt-16 pt-8 border-t border-border">
        <a href={`/${lang}/blog/`} class="text-brand-light hover:text-brand transition-colors text-sm font-medium">
          {t('blog.backToBlog')}
        </a>
      </div>
    </article>
  </main>

  <Footer lang={lang} />
</BaseLayout>
