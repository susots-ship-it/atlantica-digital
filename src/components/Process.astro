---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [1, 2, 3, 4] as const;
---

<section id="proceso" class="py-28 px-4 md:px-8 bg-surface-secondary relative">
  <div class="text-center max-w-[600px] mx-auto mb-16 reveal">
    <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-brand-light mb-4">{t('process.tag')}</span>
    <h2 class="font-display text-[clamp(2rem,4vw,2.8rem)] font-bold leading-tight mb-4">{t('process.title')}</h2>
    <p class="text-[1.05rem] text-txt-secondary leading-relaxed">{t('process.subtitle')}</p>
  </div>

  <div class="max-w-[800px] mx-auto flex flex-col relative process-line">
    {steps.map(n => (
      <div class="flex gap-8 md:gap-8 gap-5 py-8 relative reveal">
        <div class="w-[60px] h-[60px] md:w-[60px] md:h-[60px] w-10 h-10 min-w-[40px] md:min-w-[60px] rounded-full bg-surface-card border-2 border-brand flex items-center justify-center font-display font-extrabold text-xl md:text-xl text-sm text-brand-light z-[1]">
          {n}
        </div>
        <div>
          <h3 class="font-display text-xl font-bold mb-2">{t(`process.step${n}.title` as any)}</h3>
          <p class="text-txt-secondary text-sm leading-relaxed">{t(`process.step${n}.desc` as any)}</p>
        </div>
      </div>
    ))}
  </div>
</section>
