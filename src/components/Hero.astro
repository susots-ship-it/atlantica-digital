---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="min-h-screen flex items-center justify-center relative bg-gradient-to-br from-surface-primary via-[#0f1628] to-surface-primary pt-32 pb-24 px-4 md:px-8 overflow-hidden">
  <!-- Orbs -->
  <div class="absolute w-[500px] h-[500px] rounded-full blur-[100px] opacity-40 animate-orbFloat -top-[100px] -right-[100px] bg-[radial-gradient(circle,rgba(59,130,246,0.3),transparent_70%)]"></div>
  <div class="absolute w-[400px] h-[400px] rounded-full blur-[100px] opacity-40 animate-orbFloat -bottom-[50px] -left-[50px] bg-[radial-gradient(circle,rgba(6,182,212,0.2),transparent_70%)]" style="animation-delay: -6s;"></div>

  <!-- Grid -->
  <div class="absolute inset-0 hero-grid-mask" style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Content -->
  <div class="max-w-[800px] text-center relative z-[2]">
    <h1 class="font-display text-[clamp(2.8rem,6vw,4.5rem)] font-extrabold leading-[1.1] mb-6 tracking-tight animate-fadeInUp-1">
      {t('hero.title.before')}<span class="bg-gradient-to-br from-brand to-accent bg-clip-text text-transparent">{t('hero.title.highlight')}</span>{t('hero.title.after')}
    </h1>

    <p class="text-lg text-txt-secondary max-w-[560px] mx-auto mb-10 leading-relaxed animate-fadeInUp-2">
      {t('hero.subtitle')}
    </p>

    <div class="flex gap-4 justify-center flex-wrap animate-fadeInUp-3">
      <a href="#contacto" class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-br from-brand to-accent text-white rounded-full font-semibold text-[0.95rem] hover:-translate-y-0.5 hover:shadow-[0_12px_40px_rgba(59,130,246,0.35)] transition-all duration-300">
        {t('hero.cta.primary')}
      </a>
      <a href="#servicios" class="inline-flex items-center gap-2 px-8 py-3.5 bg-transparent text-txt-primary rounded-full font-semibold text-[0.95rem] border border-border-hover hover:bg-white/[0.04] hover:border-white/20 transition-all duration-300">
        {t('hero.cta.secondary')}
      </a>
    </div>

    <div class="flex justify-center gap-12 mt-16 pt-12 border-t border-border animate-fadeInUp-5">
      <div class="text-center">
        <div class="font-display text-3xl font-bold bg-gradient-to-br from-brand to-accent bg-clip-text text-transparent">{t('hero.stat1.number')}</div>
        <div class="text-xs text-txt-muted mt-1 uppercase tracking-widest font-medium">{t('hero.stat1.label')}</div>
      </div>
      <div class="text-center">
        <div class="font-display text-3xl font-bold bg-gradient-to-br from-brand to-accent bg-clip-text text-transparent">{t('hero.stat2.number')}</div>
        <div class="text-xs text-txt-muted mt-1 uppercase tracking-widest font-medium">{t('hero.stat2.label')}</div>
      </div>
      <div class="text-center">
        <div class="font-display text-3xl font-bold bg-gradient-to-br from-brand to-accent bg-clip-text text-transparent">{t('hero.stat3.number')}</div>
        <div class="text-xs text-txt-muted mt-1 uppercase tracking-widest font-medium">{t('hero.stat3.label')}</div>
      </div>
    </div>
  </div>
</section>
