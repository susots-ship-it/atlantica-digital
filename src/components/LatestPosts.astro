---
import { getCollection } from 'astro:content';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import BlogCard from './BlogCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const posts = (await getCollection('blog'))
  .filter(post => post.data.lang === lang)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

{posts.length > 0 && (
  <section class="py-28 px-4 md:px-8 bg-surface-secondary relative">
    <div class="text-center max-w-[600px] mx-auto mb-16 reveal">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-brand-light mb-4">Blog</span>
      <h2 class="font-display text-[clamp(2rem,4vw,2.8rem)] font-bold leading-tight mb-4">{t('blog.latestPosts')}</h2>
      <p class="text-[1.05rem] text-txt-secondary leading-relaxed">{t('blog.latestPostsSubtitle')}</p>
    </div>

    <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <div class="reveal">
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            slug={post.id}
            lang={lang}
            location={post.data.location}
            locationLabels={post.data.locationLabels}
            image={post.data.image}
          />
        </div>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <a
        href={`/${lang}/blog/`}
        class="inline-block px-6 py-3 text-sm font-semibold text-brand-light border border-brand rounded-full hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(59,130,246,0.2)] transition-all duration-300"
      >
        {t('blog.allPosts')}
      </a>
    </div>
  </section>
)}
